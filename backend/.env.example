# Copy to backend/.env and fill in.

DATABASE_URL=postgresql+psycopg://jobmatch:jobmatch@localhost:5433/jobmatch

# Claude — required for CV parsing and match explanations.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Embeddings: "voyage" (real, multilingual) or "mock" (offline dev, keyword-hash based).
EMBEDDING_PROVIDER=mock
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5
EMBEDDING_DIM=1024

CORS_ORIGINS=http://localhost:3000
